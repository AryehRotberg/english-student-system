{
    "$schema": "https://json.schemastore.org/nest-cli",
    "collection": "@nestjs/schematics",
    "sourceRoot": "src",
    "compilerOptions": {
        "deleteOutDir": true,
        "assets": [
            {
                "include": "**/*.sql",
                "outDir": "dist/src"
            }
        ]
    },
    "projects": {
        "worker": {
            "type": "application",
            "root": "src",
            "entryFile": "worker",
            "sourceRoot": "src",
            "compilerOptions": {
                "tsConfigPath": "tsconfig.build.json",
                "assets": [
                    {
                        "include": "**/*.sql",
                        "outDir": "dist/src"
                    }
                ]
            }
        }
    }
}
