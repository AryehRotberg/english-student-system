{
    "version": 2,
    "buildCommand": "npm run build",
    "builds": [
        {
            "src": "dist/main.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": ["dist/**/*.sql"]
            }
        }
    ],
    "routes": [{ "src": "/(.*)", "dest": "dist/main.js" }]
}
